{
  "permissions": {
    "allow": [
      "Bash(mvn spring-boot:run)",
      "Skill(claude-md-management:revise-claude-md)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "echo '代码已修改：请运行 mvn -q -DskipTests package 或 mvn test 验证。' >&2"
          }
        ]
      }
    ]
  }
}
